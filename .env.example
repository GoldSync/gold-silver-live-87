
# Pricing Source: 'API' (goldapi.io) or 'SCRAPE' (local proxy)
VITE_PRICE_SOURCE=API
# If using SCRAPE, this is the local proxy URL
VITE_PROXY_URL=http://localhost:3001/api/prices

VITE_GOLD_API_KEY=your_api_key_here

# Refresh Mode: 'MANUAL' or 'AUTO'
VITE_REFRESH_MODE=MANUAL
# Refresh Interval in ms (default 2000)
VITE_REFRESH_INTERVAL=2000
